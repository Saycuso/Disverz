generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  discordId String   @unique
  username  String
  avatar    String?
  servers   Server[] 
  createdAt DateTime @default(now())
}

model Server {
  id           String   @id @default(uuid())
  discordId    String   @unique 
  name         String
  description  String
  inviteLink   String
  ownerId      String   
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  lastBumpedAt DateTime @default(now())
  pulseScore   Int      @default(0) 
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}